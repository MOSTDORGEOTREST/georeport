# PostgreSQL (внешняя БД)
POSTGRES_USER=georeport
POSTGRES_PASSWORD=your_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_NAME=georeport

# Backend
FILE_COUNT=10
FILE_SIZE=1024
WORK_TYPE=BACKEND
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600
SUPERUSER_NAME=admin
SUPERUSER_PASSWORD=admin

# AWS S3 / MinIO
AWS_URI=http://minio:9000
AWS_ACCCESS_KEY=minioadmin
AWS_SERVICE_NAME=s3
AWS_SECRET_KEY=minioadmin
AWS_REGION=us-east-1
AWS_BUCKET=georeport
